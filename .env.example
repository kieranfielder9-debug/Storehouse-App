# --- Client (Vite) — presence of these switches the app from Sandbox to Live ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Separate opt-in gate for real Plaid Link (Phase 2). Going Supabase-live does
# NOT alone route "Connect" to real Plaid functions — set this to 'true' only
# once PLAID_CLIENT_ID/PLAID_SECRET are actually configured below.
VITE_PLAID_LIVE=

# --- Server-side only (Netlify function env vars — never exposed to browser) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
